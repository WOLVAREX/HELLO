# ════════════════════════════════════════════════════════
#   🦊  FOXY BOT — Environment Variables Template
#   Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────
# Your WhatsApp session ID (must begin with FOXY-BOT:)
SESSION_ID=

# ── OWNER ────────────────────────────────────────────────
# Your WhatsApp number in international format without +
# Example: 254712345678
OWNER_NUMBER=

# ── BOT IDENTITY ─────────────────────────────────────────
BOT_NAME=FOXY BOT
BOT_PREFIX=.
# Modes: public | private | group | solo | sudo | super | buttons | channel
BOT_MODE=public
# Timezone: e.g. Africa/Nairobi | Asia/Kolkata | America/New_York | UTC
BOT_TIMEZONE=UTC

# ── DATABASE (optional) ───────────────────────────────────
# PostgreSQL connection string — leave blank to use SQLite
# Supports Heroku Postgres, Supabase, Neon, Railway, etc.
# Format: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ── PTERODACTYL PANEL (optional) ─────────────────────────
# Required only if you use .cpanel / panel management commands
PTERODACTYL_URL=
PTERODACTYL_KEY=

# ── PAYMENTS (optional) ───────────────────────────────────
# Paystack secret key — required only for payment features
# Format: sk_live_... or sk_test_...
PAYSTACK_KEY=

# ── NODE ─────────────────────────────────────────────────
NODE_ENV=production
